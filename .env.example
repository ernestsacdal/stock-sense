# Database — connect as the dedicated app role, never as superuser.
DATABASE_URL=postgresql+psycopg://stocksense_app:CHANGE_ME@localhost:5432/stocksense_dev

# Comma-separated list of allowed CORS origins. Includes :3000 for the
# normal dev server and :3001 for the Playwright suite's parallel server.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# JWT — generate a fresh JWT_SECRET (32+ random bytes hex) for every environment.
JWT_SECRET=CHANGE_ME_to_a_long_random_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Refresh token cookie — Secure must be true behind HTTPS (production).
REFRESH_COOKIE_NAME=stocksense_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_DOMAIN=

# OpenRouter API key for the AI chat. Empty = AI features run in stub
# mode (deterministic, no network). Sign up at https://openrouter.ai
# to get a key; pay-as-you-go credits, no monthly minimum.
OPENROUTER_API_KEY=

# OpenRouter model slug. Defaults to DeepSeek V3 (cheap + strong at
# SQL/reasoning). Other tested-cheap options:
#   deepseek/deepseek-chat      (default — DeepSeek V3, fast + cheap)
#   deepseek/deepseek-r1        (reasoning model, slower + pricier)
#   qwen/qwen-2.5-72b-instruct  (alternative open-weight)
OPENROUTER_MODEL=deepseek/deepseek-chat

# Password the AI executor uses when connecting as stocksense_ai_ro
# (the read-only Postgres role for SQL safety). Must match what you
# used when running CREATE USER stocksense_ai_ro WITH PASSWORD '...'.
# Default in code is "dev_ai_ro_password" — set this in prod.
AI_RO_PASSWORD=
